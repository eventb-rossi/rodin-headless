#!/usr/bin/env bash
# Thin wrapper around the rodin-headless toolchain.
# Runs against a native Rodin install when one is available, otherwise
# falls back to the rodin-headless Docker image (auto-built on first run).
#
# Usage: ./rodin <command> [args...]
#   Commands are the same in both modes (build, check, prove, validate,
#   autoprove, probcli, help). See ./rodin help for details.
#
# Runtime selection (RODIN_RUNTIME=auto|native|docker|podman, default auto):
#   1. RODIN_DIR pointing at a Rodin install (rodin.ini present) -> native
#   2. ./rodin-install.sh default prefix install                 -> native
#   3. docker or podman available                                -> container
# Set RODIN_RUNTIME=docker (or podman) to skip native detection.

set -euo pipefail

IMAGE="rodin-headless"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=rodin-headless-lib.sh
. "$SCRIPT_DIR/rodin-headless-lib.sh"
PLATFORM_ARGS=()

case "${1:-}" in
    help|--help|-h)
        exec bash "$SCRIPT_DIR/entrypoint.sh" help
        ;;
esac

find_native_rodin() {
    if [ -n "${RODIN_DIR:-}" ]; then
        if resolve_rodin_home "$RODIN_DIR" >/dev/null; then
            printf '%s\n' "$RODIN_DIR"
            return 0
        fi
        echo "Warning: RODIN_DIR=$RODIN_DIR has no rodin.ini; ignoring it" >&2
    fi
    # Only auto-select a default-prefix install that is complete (the
    # engine needs de.prob.core even for plain builds) — a half-finished
    # install must not shadow a working container fallback. An
    # underivable prefix (no RODIN_PREFIX, no HOME) just means "no
    # native install" on the detect side, so the error is silenced.
    local default_dir
    default_dir="$(default_rodin_prefix 2>/dev/null)/rodin" || return 1
    if resolve_rodin_home "$default_dir" >/dev/null && [ -n "$(find_prob_plugin "$default_dir")" ]; then
        printf '%s\n' "$default_dir"
        return 0
    fi
    return 1
}

run_native() {
    local rodin_dir="$1"
    shift
    echo "Using native Rodin at $rodin_dir" >&2

    local prob_dir
    prob_dir="$(dirname "$rodin_dir")/prob"
    if [ -x "$prob_dir/probcli" ]; then
        export PATH="$prob_dir:$PATH"
    fi

    RODIN_DIR="$rodin_dir" MODELS_DIR="$(pwd)" \
        exec "$SCRIPT_DIR/entrypoint.sh" "$@"
}

RODIN_RUNTIME="${RODIN_RUNTIME:-auto}"

RUNTIME=""
case "$RODIN_RUNTIME" in
    auto|native)
        if NATIVE_RODIN_DIR="$(find_native_rodin)"; then
            # In auto mode a GUI-less macOS host (ssh, CI) skips the
            # native install instead of fast-failing in the engine —
            # the container runtime works without a desktop session.
            # Forced native runs proceed and hit the engine's check.
            if darwin_gui_session_ok; then
                # Session just verified — spare the engine its
                # duplicate probe.
                RODIN_SKIP_GUI_CHECK=1 run_native "$NATIVE_RODIN_DIR" "$@"
            elif [ "$RODIN_RUNTIME" = native ]; then
                run_native "$NATIVE_RODIN_DIR" "$@"
            else
                echo "Note: skipping native Rodin at $NATIVE_RODIN_DIR (no graphical session for SWT); using a container" >&2
                echo "      (RODIN_RUNTIME=native forces the native install, RODIN_SKIP_GUI_CHECK=1 skips this probe)" >&2
            fi
        fi
        if [ "$RODIN_RUNTIME" = native ]; then
            echo "Error: no native Rodin install found" >&2
            echo "Run ./rodin-install.sh, or point RODIN_DIR at a Rodin install" >&2
            exit 1
        fi
        ;;
    docker|podman)
        if ! command -v "$RODIN_RUNTIME" >/dev/null 2>&1; then
            echo "Error: RODIN_RUNTIME=$RODIN_RUNTIME but $RODIN_RUNTIME is not installed" >&2
            exit 1
        fi
        RUNTIME="$RODIN_RUNTIME"
        ;;
    *)
        echo "Error: RODIN_RUNTIME must be auto, native, docker, or podman (got '$RODIN_RUNTIME')" >&2
        exit 1
        ;;
esac

# Detect container runtime (auto mode falls through to here)
if [ -z "$RUNTIME" ]; then
    if command -v docker >/dev/null 2>&1; then
        RUNTIME=docker
    elif command -v podman >/dev/null 2>&1; then
        RUNTIME=podman
    else
        echo "Error: docker or podman required (or run ./rodin-install.sh for a native install)" >&2
        exit 1
    fi
fi

# Rodin and ProB only publish Linux x86_64 artifacts for the container path.
# On arm64 hosts (Apple Silicon, Linux aarch64), build an amd64 image so
# those binaries can run under emulation instead of being unpacked into an
# arm64 image that cannot execute them.
case "$(host_arch)" in
    arm64|aarch64)
        PLATFORM_ARGS=(--platform linux/amd64)
        ;;
esac

image_needs_build() {
    local image_arch

    if ! "$RUNTIME" image inspect "$IMAGE" >/dev/null 2>&1; then
        return 0
    fi

    if [ ${#PLATFORM_ARGS[@]} -gt 0 ]; then
        image_arch="$("$RUNTIME" image inspect --format '{{.Architecture}}' "$IMAGE" 2>/dev/null || true)"
        case "$image_arch" in
            amd64|x86_64)
                return 1
                ;;
            *)
                return 0
                ;;
        esac
    fi

    return 1
}

# The host prefixes the default podman machine shares with its VM, one
# per line. podman 5.x dropped the Mounts field from machine inspect
# but records them in the machine's config file; 4.x lacks ConfigDir
# and answers the inspect template instead. The config file comes
# first so modern podman pays a single inspect.
podman_machine_mounts() {
    local config_file

    if config_file="$("$RUNTIME" machine inspect \
        --format '{{.ConfigDir.Path}}/{{.Name}}.json' 2>/dev/null)" \
        && [ -f "$config_file" ]; then
        # The file is single-line JSON; grep -o picks up every mount
        # where a line-oriented sed would only see the last one.
        grep -o '"Source"[[:space:]]*:[[:space:]]*"[^"]*"' "$config_file" \
            | sed 's/.*"\([^"]*\)"$/\1/'
        return 0
    fi

    "$RUNTIME" machine inspect \
        --format '{{range .Mounts}}{{.Source}}{{"\n"}}{{end}}' 2>/dev/null
}

# Podman on macOS runs containers in a VM that bind-mounts only a fixed
# set of host prefixes (typically /Users, /private, /var/folders); a
# cwd outside them (e.g. /Volumes/...) only surfaces as an opaque
# "statfs ... no such file or directory" from the runtime. Check up
# front and explain the fix. Docker Desktop shares /Volumes by default,
# so only podman is checked; a podman whose mounts cannot be listed
# skips the check rather than misfiring.
check_podman_machine_shares_cwd() {
    local mounts cwd top src

    [ "$(host_os)" = Darwin ] || return 0
    [ "$RUNTIME" = podman ] || return 0
    mounts="$(podman_machine_mounts)" || return 0
    [ -n "$mounts" ] || return 0

    # Physical path: macOS /tmp and /var are symlinks into /private,
    # which IS shared — the logical pwd would be falsely rejected.
    cwd="$(pwd -P)"
    # The heredoc feeds the loop in this shell, so a match can return
    # from the function directly.
    while IFS= read -r src; do
        [ -n "$src" ] || continue
        case "$cwd/" in
            "${src%/}"/*) return 0 ;;
        esac
    done <<EOF
$mounts
EOF

    top="${cwd#/}"
    top="/${top%%/*}"
    echo "Error: podman machine does not share $cwd with its VM" >&2
    echo "Shared prefixes: $(printf '%s\n' "$mounts" | tr '\n' ' ')" >&2
    echo "Run from a directory under a shared prefix (e.g. \$HOME), or share this one:" >&2
    echo "  podman machine stop && podman machine set --volume $top:$top && podman machine start" >&2
    exit 1
}
check_podman_machine_shares_cwd

# Auto-detect SELinux volume flag
VOLUME_FLAG=""
if [ -f /etc/selinux/config ] && grep -q 'SELINUX=enforcing' /etc/selinux/config 2>/dev/null; then
    VOLUME_FLAG=":Z"
fi

# Build image if not present, or if an existing Apple Silicon image has the
# wrong architecture for Rodin/ProB's Linux x86_64 binaries.
if image_needs_build; then
    echo "Building $IMAGE image..."
    # ${arr[@]+...} keeps the empty-array expansion alive under bash
    # 3.2's set -u (stock macOS), where a bare "${arr[@]}" is fatal.
    "$RUNTIME" build ${PLATFORM_ARGS[@]+"${PLATFORM_ARGS[@]}"} -t "$IMAGE" "$SCRIPT_DIR"
fi

# Rootless engines map container root to the invoking host user, so
# files written into the bind mount already come back correctly owned;
# forcing a uid there would shift ownership into the subuid range and
# lose write access to the mount. An undeterminable engine counts as
# rootful — the rootful default (root-owned output) is the case worth
# fixing.
runtime_is_rootless() {
    case "$RUNTIME" in
        docker)
            "$RUNTIME" info --format '{{.SecurityOptions}}' 2>/dev/null \
                | grep -q 'name=rootless'
            ;;
        podman)
            [ "$("$RUNTIME" info --format '{{.Host.Security.Rootless}}' 2>/dev/null)" = true ]
            ;;
        *)
            return 1
            ;;
    esac
}

# Run rootful containers as the host user so repackaged zips in the
# mounted cwd are not root-owned. The host uid has no passwd entry in
# the image, so HOME=/tmp gives Equinox (~/.eclipse), ProB (~/.prob),
# and Java preferences a writable home. Possible only because the
# engine never writes to the /opt/rodin install.
# For a root invoker the mapping is a no-op, so skip the engine's
# daemon round-trip entirely.
USER_ARGS=()
if [ "$(id -u)" -ne 0 ] && ! runtime_is_rootless; then
    USER_ARGS=(--user "$(id -u):$(id -g)" -e HOME=/tmp)
fi

exec "$RUNTIME" run --rm \
    ${PLATFORM_ARGS[@]+"${PLATFORM_ARGS[@]}"} \
    ${USER_ARGS[@]+"${USER_ARGS[@]}"} \
    -e RODIN_BUILD_TIMEOUT \
    -e RODIN_BUILD_TIMEOUT_KILL_AFTER \
    -v "$(pwd):/models${VOLUME_FLAG}" \
    "$IMAGE" "$@"
